{
  "name": "rescript",
  "sources": [
    {
      "dir": "src",
      "subdirs": true
    }
  ],
  "package-specs": [
    {
      "module": "esmodule",
      "in-source": true
    }
  ],
  "suffix": ".res.mjs",
  "jsx": {
    "version": 4
  },
  "dependencies": [
    "@rescript/react",
    "@glennsl/rescript-fetch",
    "@glennsl/rescript-json-combinators"
  ],
  "compiler-flags": [
    "-open JsonCombinators"
  ]
}